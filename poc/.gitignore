# =============================================================================
# OLAP POC — .gitignore
# =============================================================================

# Secrets — NEVER commit
.env
secrets/
*.key
*.pem
*.json.creds
gcs-sa.json

# Generated data (too large for git)
/opt1/
data/event_fact/
data/*.parquet
data/manifest.json
data/upload_manifest.json

# Benchmark results (commit selectively, not all runs)
results/*.jsonl

# Charts (regenerated by analyse_results.py)
report/03_charts/*.png
report/01_raw_results.csv

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/

# DuckDB runtime files
*.duckdb
*.duckdb.wal
duckdb/spill/

# Docker
.docker/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Temp
tmp/
temp/
