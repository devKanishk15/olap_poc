# =============================================================================
# OLAP POC — Environment Configuration Template
# Copy to .env and fill in real values. NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# GCS Bucket Configuration
# -----------------------------------------------------------------------------
GCS_BUCKET=your-gcs-bucket-name
GCS_BUCKET_PREFIX=olap_poc/data       # prefix inside the bucket where data lives

# HMAC Key (works with all three engines via S3-compatible API)
GCS_HMAC_ACCESS_KEY=GOOGXXXXXXXXXXXXXXXX
GCS_HMAC_SECRET=your-hmac-secret-here

# S3-compatible endpoint for GCS
GCS_S3_ENDPOINT=https://storage.googleapis.com

# Alternative: Service Account JSON (for DuckDB gcs extension)
GCS_SA_JSON_PATH=/opt1/secrets/gcs-sa.json

# GCS region (used by some engines; GCS uses "auto" or "us-central1" etc.)
GCS_REGION=auto

# -----------------------------------------------------------------------------
# Engine Versions (used by install scripts and Docker Compose files)
# -----------------------------------------------------------------------------
DORIS_VERSION=2.1.7
DORIS_FE_IMAGE=apache/doris:fe-2.1.7
DORIS_BE_IMAGE=apache/doris:be-2.1.7

DUCKDB_VERSION=1.2.1
DUCKDB_BINARY_URL=https://github.com/duckdb/duckdb/releases/download/v1.2.1/duckdb_cli-linux-amd64.zip

CLICKHOUSE_VERSION=24.12
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24.12

# -----------------------------------------------------------------------------
# Data Configuration
# -----------------------------------------------------------------------------
DATA_DIR=/opt1/data
RESULTS_DIR=/opt1/poc/results
LOGS_DIR=/opt1/logs
POC_DIR=/opt1/poc

# Row count for synthetic dataset
DATA_ROW_COUNT=10000000
DATA_SEED=42                          # Deterministic seed — do not change

# Parquet partition column and number of partitions
DATA_PARTITION_COL=event_date
DATA_NUM_PARTITIONS=30

# -----------------------------------------------------------------------------
# Engine Connection Details (defaults — override if ports conflict)
# -----------------------------------------------------------------------------
DORIS_HOST=127.0.0.1
DORIS_FE_HTTP_PORT=8030
DORIS_FE_QUERY_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=

DUCKDB_DB_PATH=/opt1/duckdb/benchmark.duckdb

CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=poc

# -----------------------------------------------------------------------------
# Benchmark Harness Settings
# -----------------------------------------------------------------------------
WARM_ITERATIONS=5
QUERY_TIMEOUT_SECONDS=300
DROP_CACHES_BETWEEN_COLD_RUNS=true
